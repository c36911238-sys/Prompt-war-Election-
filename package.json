  "engines": { 
    "node": ">=20.9.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx --fix",
    "lint:check": "eslint . --ext .js,.jsx",
    "format": "prettier --write \"**/*.{js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,json,md,css}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "analyze": "ANALYZE=true npm run build",
    "type-check": "tsc --noEmit",
    "quality": "npm run lint:check && npm run format:check && npm run test:coverage",
    "deploy": "vercel --prod",
    "preview": "vercel"
  },
  "dependencies": {
    "@google-cloud/text-to-speech": "^6.4.1",
    "@google-cloud/translate": "^9.4.1",
    "@google-cloud/vertexai": "^1.12.0",
    "@next/third-parties": "^16.2.4",
    "dompurify": "^3.4.2",
    "firebase": "^12.12.1",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@eslint/js": "^9.17.0",
    "@next/eslint-plugin-next": "^16.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-fetch-mock": "^3.0.3",
    "prettier": "^3.4.2",
    "tailwindcss": "^4",
    "webpack-bundle-analyzer": "^4.10.2"
  }
