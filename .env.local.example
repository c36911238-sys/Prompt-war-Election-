# Prompt-war-Election — Environment Variables
#
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
#
# ─────────────────────────────────────────────────────
# Security Configuration
# ─────────────────────────────────────────────────────

# JWT Secret for session management (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-here

# API Keys for external services (if needed)
# API_KEY_SECRET=your-api-key-secret

# CSRF Secret (generate with: openssl rand -base64 32)
CSRF_SECRET=your-csrf-secret-here

# Session encryption key (generate with: openssl rand -base64 32)
SESSION_SECRET=your-session-secret-here

# ─────────────────────────────────────────────────────
# Monitoring and Logging
# ─────────────────────────────────────────────────────

# Monitoring service endpoints (optional)
# MONITORING_ENDPOINT=https://your-monitoring-service.com/api/logs
# SECURITY_MONITORING_ENDPOINT=https://your-security-service.com/api/events

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# ─────────────────────────────────────────────────────
# Google Cloud (Vertex AI + Translate + Text-to-Speech)
# ─────────────────────────────────────────────────────

# Option A (local dev): path to your service-account JSON file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json

# Option B (Railway deployment): raw JSON string of the service account
# Use this for Railway deployment - paste the entire service account JSON
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Your Google Cloud project ID (required)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ─────────────────────────────────────────────────────
# Railway Configuration (automatically set by Railway)
# ─────────────────────────────────────────────────────

# Railway automatically sets PORT - no need to configure
# PORT=3000

# ─────────────────────────────────────────────────────
# Firebase (Auth + Firestore + Analytics + Remote Config)
# All NEXT_PUBLIC_ vars are exposed to the browser.
# ─────────────────────────────────────────────────────

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─────────────────────────────────────────────────────
# Security Headers and CSP Configuration
# ─────────────────────────────────────────────────────

# Enable strict CSP (true/false)
ENABLE_STRICT_CSP=true

# Additional allowed domains for CSP (comma-separated)
# CSP_ALLOWED_DOMAINS=example.com,trusted-domain.com

# ─────────────────────────────────────────────────────
# Rate Limiting Configuration
# ─────────────────────────────────────────────────────

# Rate limit for API endpoints (requests per minute)
RATE_LIMIT_API=100
RATE_LIMIT_CHAT=20
RATE_LIMIT_TTS=30
RATE_LIMIT_AUTH=5

# Rate limit window in milliseconds
RATE_LIMIT_WINDOW=60000

# ─────────────────────────────────────────────────────
# Optional: Google Analytics (legacy — now handled by Firebase Analytics)
# ─────────────────────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
